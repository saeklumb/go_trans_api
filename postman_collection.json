{
	"info": {
		"name": "Go Transaction API",
		"description": "Микросервис для обработки транзакций с защитой от двойного списания",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Health Check",
			"request": {
				"method": "GET",
				"url": {
					"raw": "http://localhost:8080/health",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["health"]
				}
			}
		},
		{
			"name": "2. Получить баланс (User 1)",
			"request": {
				"method": "GET",
				"url": {
					"raw": "http://localhost:8080/api/v1/wallets/1",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "v1", "wallets", "1"]
				}
			}
		},
		{
			"name": "3. Сделать перевод (User 1 -> User 2)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Idempotency-Key",
						"value": "test-key-12345",
						"description": "Ключ идемпотентности. Меняй его для новых переводов."
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"from_user_id\": 1,\n  \"to_user_id\": 2,\n  \"amount\": 100,\n  \"description\": \"Перевод средств\"\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/v1/transfers",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "v1", "transfers"]
				}
			}
		},
		{
			"name": "4. Получить баланс (User 2)",
			"request": {
				"method": "GET",
				"url": {
					"raw": "http://localhost:8080/api/v1/wallets/2",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "v1", "wallets", "2"]
				}
			}
		}
	]
}
